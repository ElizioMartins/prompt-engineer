# MySQL Database (HaskHosting)
DB_HOST=localhost
DB_PORT=3306
DB_USER=seu_usuario_mysql
DB_PASSWORD=sua_senha_mysql
DB_DATABASE=PromptEngineer

# Server
PORT=3000
NODE_ENV=development

# App URL (para OpenRouter HTTP-Referer)
APP_URL=http://localhost:3000

# OpenRouter API Key (OPCIONAL - usuário configura no frontend via localStorage)
# OPENROUTER_API_KEY=sk-or-v1-...
